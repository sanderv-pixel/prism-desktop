{
  "name": "prism-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@prism/web",
    "dev:web": "npm run dev --workspace=@prism/web",
    "build": "npm run build --workspace=@prism/web",
    "build:web": "npm run build --workspace=@prism/web",
    "start": "npm run start --workspace=@prism/web",
    "lint": "npm run lint --workspace=@prism/web",
    "typecheck": "npm run lint",
    "deploy:web": "cd apps/web && vercel --prod"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}
