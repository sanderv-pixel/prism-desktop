# =============================================================================
# Prism Monorepo - Environment Variables
# Copy this file to .env.local for local development and fill in your values.
# NEVER commit .env.local or any other file containing secrets.
# In production, inject these via your hosting platform (Vercel, Fly, etc.).
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Stripe (required for advertiser billing and payouts)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_ID=price_...

# -----------------------------------------------------------------------------
# Prism (all required in production)
# -----------------------------------------------------------------------------
# Public URL of the deployed web app. Used for safe redirects and Stripe URLs.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Base URL for the Prism web API. Must be reachable by the browser extension, CLI,
# and editor extension.
PRISM_API_URL=https://your-domain.com/api

# Comma-separated list of strong API keys for extension/CLI clients.
# The server will refuse public API requests in production if this is empty.
PRISM_API_KEYS=pk_live_xxxxxxxx, pk_live_yyyyyyyy

# Long random secret used to sign impression tokens.
# The app will refuse to start in production without it.
PRISM_IMPRESSION_SECRET=long-random-string-min-64-chars

# Comma-separated list of admin emails. These accounts can approve/reject campaigns.
PRISM_ADMIN_EMAILS=admin@your-domain.com, reviewer@your-domain.com

# Optional second factor for admin API routes. When set, admin endpoints require
# the X-Admin-Secret header to match this value. Strongly recommended in production.
PRISM_ADMIN_SECRET=long-random-admin-secret

# -----------------------------------------------------------------------------
# Redis (required in production)
# Without Redis, rate limits, nonce replay protection, fraud velocity counters,
# and Stripe webhook idempotency are stored in-memory and will not work across
# multiple server instances.
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# -----------------------------------------------------------------------------
# Cloudflare Turnstile (required in production)
# Sign-up CAPTCHA protection.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# -----------------------------------------------------------------------------
# Demo auth (optional, default false)
# Set DEMO_AUTH_ENABLED=true and a strong random secret to enable a demo/bypass
# auth mode for local testing. Leave disabled in production.
# -----------------------------------------------------------------------------
DEMO_AUTH_ENABLED=false
DEMO_AUTH_SECRET=

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
NODE_ENV=production
