{
  "name": "prism",
  "displayName": "Prism",
  "description": "Get paid while AI codes. Contextual ads for AI builders.",
  "version": "0.1.12",
  "private": true,
  "publisher": "prism",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/prism-ai/prism"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Machine Learning",
    "Visualization"
  ],
  "keywords": [
    "ai",
    "ads",
    "cursor",
    "copilot",
    "monetization",
    "builders"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**/*",
    "icon.png",
    "README.md",
    "CHANGELOG.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "prism.enable",
        "title": "Enable Prism",
        "category": "Prism"
      },
      {
        "command": "prism.disable",
        "title": "Disable Prism",
        "category": "Prism"
      },
      {
        "command": "prism.hideAdvertiser",
        "title": "Hide this advertiser",
        "category": "Prism"
      },
      {
        "command": "prism.openAd",
        "title": "Open Prism ad",
        "category": "Prism"
      },
      {
        "command": "prism.refresh",
        "title": "Refresh Prism status",
        "category": "Prism"
      },
      {
        "command": "prism.test",
        "title": "Test Prism ad",
        "category": "Prism"
      },
      {
        "command": "prism.version",
        "title": "Show Prism version",
        "category": "Prism"
      },
      {
        "command": "prism.checkForUpdates",
        "title": "Check for Prism updates",
        "category": "Prism"
      },
      {
        "command": "prism.patchPanel",
        "title": "Patch Claude Code panel",
        "category": "Prism"
      },
      {
        "command": "prism.patchCodex",
        "title": "Patch OpenAI Codex panel",
        "category": "Prism"
      },
      {
        "command": "prism.openDashboard",
        "title": "Open dashboard to connect account",
        "category": "Prism"
      },
      {
        "command": "prism.restorePanel",
        "title": "Restore Claude Code panel",
        "category": "Prism"
      },
      {
        "command": "prism.restoreCodex",
        "title": "Restore OpenAI Codex panel",
        "category": "Prism"
      },
      {
        "command": "prism.patchClaudeDesktop",
        "title": "Patch Claude for Desktop",
        "category": "Prism"
      },
      {
        "command": "prism.restoreClaudeDesktop",
        "title": "Restore Claude for Desktop",
        "category": "Prism"
      }
    ],
    "configuration": {
      "title": "Prism",
      "properties": {
        "prism.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Prism ads during AI wait states"
        },
        "prism.apiUrl": {
          "type": "string",
          "default": "https://goprism.dev/api",
          "description": "Prism API base URL"
        },
        "prism.userId": {
          "type": "string",
          "default": "",
          "description": "Anonymous Prism user identifier"
        },
        "prism.apiKey": {
          "type": "string",
          "default": "9939cb7a62009a94432723424a82a22af43d9e529ab13171856926fa8eef5dcb",
          "description": "Prism API key for authenticated extension requests"
        },
        "prism.deviceApiKey": {
          "type": "string",
          "default": "",
          "description": "Per-install Prism device API key (auto-generated on first run)"
        },
        "prism.showAdsWhenNoWait": {
          "type": "boolean",
          "default": false,
          "description": "Show a Prism ad even when no AI wait state is detected (demo mode)"
        },
        "prism.minimumWaitMs": {
          "type": "number",
          "default": 1500,
          "description": "Minimum wait time (ms) before showing an ad"
        },
        "prism.patchPanel": {
          "type": "boolean",
          "default": true,
          "description": "Automatically patch the Claude Code panel to show Prism ads inside Claude Code"
        },
        "prism.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically download and install Prism extension updates from the configured update URL"
        },
        "prism.updateUrl": {
          "type": "string",
          "default": "https://goprism.dev/extension/latest.json",
          "description": "URL of the JSON manifest used for self-updates"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle",
    "compile": "tsc -p ./",
    "bundle": "npm run compile && ../../node_modules/.bin/esbuild ./out/extension.js --bundle --platform=node --outfile=./out/extension.js --allow-overwrite --external:vscode",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "package:cursor": "vsce package --no-dependencies --out prism-cursor.vsix",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies",
    "publish": "npm run publish:vsce && npm run publish:ovsx",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:smoke": "npm run bundle && node -e \"require('./out/extension.js')\""
  },
  "dependencies": {
    "@prism/patcher": "*",
    "@prism/shared": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3",
    "ovsx": "^0.10.0",
    "tsx": "^4",
    "typescript": "^5"
  }
}
