# Prism production environment template (deploy to Vercel)
# Copy these into your Vercel project settings.

NEXT_PUBLIC_SITE_URL=https://goprism.dev

# Supabase (same project used in development)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Upstash Redis (used for rate limiting and ad rotation)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# API keys for authenticated extension requests
PRISM_API_KEYS=your-extension-api-key

# Impression signing secret
PRISM_IMPRESSION_SECRET=your-impression-secret

# Admin emails (comma-separated)
PRISM_ADMIN_EMAILS=admin@goprism.dev

# Admin second-factor secret (required in production)
PRISM_ADMIN_SECRET=your-admin-secret

# Cloudflare Turnstile (anti-bot)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
TURNSTILE_WORKER_URL=https://your-worker.your-subdomain.workers.dev

# Google Analytics 4 (optional — pulls visitor data into admin dashboard)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
GOOGLE_ANALYTICS_PROPERTY_ID=123456789
GOOGLE_ANALYTICS_PROJECT_ID=your-gcp-project-id
GOOGLE_ANALYTICS_CLIENT_EMAIL=analytics@your-gcp-project-id.iam.gserviceaccount.com
GOOGLE_ANALYTICS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
